# Application
APP_NAME="WAGW"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=wagw_db
DB_USERNAME=wagw_user
DB_PASSWORD=wagw_password
DB_ROOT_PASSWORD=rootpassword

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# Cache & Queue
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Node.js Worker
WA_URL_SERVER=http://node:3000
SOCKET_SERVER=http://node:3000
PORT_NODE=3000
NODE_ENV=production

# API Configuration
API_KEY_SECRET=your-secret-key-here

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@wagw.local"
MAIL_FROM_NAME="${APP_NAME}"

# AI API Keys (Optional)
OPENAI_API_KEY=
CLAUDE_API_KEY=
GEMINI_API_KEY=

# Docker Ports
APP_PORT=80
APP_HTTPS_PORT=443
NODE_PORT=3000
PHPMYADMIN_PORT=8080
